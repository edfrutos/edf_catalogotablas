# Environment Configuration for EDF Catálogo de Tablas
# Copy this file to .env and update with your values

# ============================================================
# REQUIRED - Must be set in production
# ============================================================

# Flask Secret Key (min 32 characters)
# Generate with: openssl rand -base64 32
SECRET_KEY=your_secret_key_here_minimum_32_chars

# MongoDB Configuration
# OPTION 1: MongoDB Atlas (Cloud) - RECOMMENDED
#   Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
#   Example: mongodb+srv://user:pass@cluster0.abc123.mongodb.net/edf_catalogotablas?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/edf_catalogotablas?retryWrites=true&w=majority

# OPTION 2: Local MongoDB (if not using Atlas)
#   MONGO_URI=mongodb://admin:password@localhost:27017/edf_catalogotablas?authSource=admin

# Redis Password (if using Redis container)
REDIS_PASSWORD=your_redis_password_here

# ============================================================
# OPTIONAL - Application Configuration
# ============================================================

# Flask Environment (development, staging, production)
FLASK_ENV=production

# Application Port
APP_PORT=5002

# Upload Folder (inside container)
UPLOAD_FOLDER=/app/uploads

# Log Directory (inside container)
LOG_DIR=/app/logs

# ============================================================
# OPTIONAL - AWS S3 Configuration
# ============================================================

# Enable S3 storage
USE_S3=false

# AWS Credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# ============================================================
# OPTIONAL - Email Configuration (Gmail, SendGrid, etc)
# ============================================================

MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER_NAME=EDF Catálogo
MAIL_DEFAULT_SENDER_EMAIL=no-reply@edefrutos.xyz

# ============================================================
# OPTIONAL - Emergency Access (Development Only)
# ============================================================

# Only for FLASK_ENV=development
EMERGENCY_TOKEN=

# ============================================================
# OPTIONAL - Security Settings
# ============================================================

SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ============================================================
# MongoDB Atlas Setup Instructions
# ============================================================
# 
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create account / login
# 3. Create a cluster (free tier available)
# 4. Create database user:
#    - Click "Database Access"
#    - Click "Add New Database User"
#    - Username: (choose)
#    - Password: (generate strong password)
# 5. Whitelist IP:
#    - Click "Network Access"
#    - Click "Add IP Address"
#    - For development: 0.0.0.0/0 (allow all)
#    - For production: your server IP
# 6. Get connection string:
#    - Click "Clusters"
#    - Click "Connect"
#    - Choose "Connect your application"
#    - Copy the connection string
#    - Replace <username>, <password>, and database name
# 
# Example result:
# MONGO_URI=mongodb+srv://myuser:mypassword@cluster0.abc123.mongodb.net/edf_catalogotablas?retryWrites=true&w=majority
#
