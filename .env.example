# Environment Configuration for EDF Catálogo de Tablas
# Copy this file to .env and update with your values

# ============================================================
# REQUIRED - Must be set in production
# ============================================================

# Flask Secret Key (min 32 characters)
# Generate with: openssl rand -base64 32
SECRET_KEY=your_secret_key_here_minimum_32_chars

# MongoDB Root Password
MONGO_ROOT_PASSWORD=your_mongodb_password_here

# Redis Password
REDIS_PASSWORD=your_redis_password_here

# ============================================================
# OPTIONAL - Application Configuration
# ============================================================

# Flask Environment (development, staging, production)
FLASK_ENV=production

# Application Port
APP_PORT=5002

# Upload Folder (inside container)
UPLOAD_FOLDER=/app/uploads

# Log Directory (inside container)
LOG_DIR=/app/logs

# ============================================================
# OPTIONAL - AWS S3 Configuration
# ============================================================

# Enable S3 storage
USE_S3=false

# AWS Credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# ============================================================
# OPTIONAL - Email Configuration (Gmail, SendGrid, etc)
# ============================================================

MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER_NAME=EDF Catálogo
MAIL_DEFAULT_SENDER_EMAIL=no-reply@edefrutos.xyz

# ============================================================
# OPTIONAL - Emergency Access (Development Only)
# ============================================================

# Only for FLASK_ENV=development
EMERGENCY_TOKEN=

# ============================================================
# OPTIONAL - Security Settings
# ============================================================

SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
